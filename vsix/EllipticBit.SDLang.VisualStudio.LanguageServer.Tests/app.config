<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <runtime>
	<!--
	  Explicit binding redirect for System.Threading.Tasks.Extensions.

	  AutoGenerateBindingRedirects emits redirects for System.Memory and System.Runtime.CompilerServices.Unsafe
	  but does NOT emit one for System.Threading.Tasks.Extensions, because the conflicting 4.2.0.1 reference is
	  pulled in transitively (by the MSTest adapter / Polyfill ValueTask surface) and is not flagged at build
	  time. Without this redirect the net472 test host throws ReflectionTypeLoadException during discovery and
	  reports "No test is available". The 4.6.3 package ships assembly version 4.2.4.0.

	  The remaining redirects are merged in automatically by AutoGenerateBindingRedirects.
	-->
	<assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
	  <dependentAssembly>
		<assemblyIdentity name="System.Threading.Tasks.Extensions" publicKeyToken="cc7b13ffcd2ddd51" culture="neutral" />
		<bindingRedirect oldVersion="0.0.0.0-4.2.4.0" newVersion="4.2.4.0" />
	  </dependentAssembly>
	</assemblyBinding>
  </runtime>
</configuration>
