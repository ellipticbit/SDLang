<Project Sdk="Microsoft.NET.Sdk">

	<!--
	EllipticBit.SDLang.VisualStudio.LanguageServer is the in-proc language ENGINE for SDLang. It is intentionally
	"lightweight LSP": there is no external process and no JSON-RPC server socket. Instead it exposes the parse +
	validate + IntelliSense capabilities as plain async methods (SdlLanguageEngine) that the editor layer calls
	directly, and it adapts the same engine onto the public brokered ISdlLanguageService (SdlLanguageService) so
	legacy/out-of-MEF consumers (for example the Visual D dub.sdl plug-in) can reach it via IServiceBroker.

	It bridges two assemblies:
	  - EllipticBit.SDLang.Analysis  -> the shared-source net472 parser/DOM/diagnostics.
	  - EllipticBit.SDLang.VisualStudio.Contracts -> the public, editor-free models and MEF/brokered contracts.

	The engine owns the impedance match between the two diagnostic models: core SdlDiagnostic uses 1-based line/
	position with UTF-8 BYTE offsets, while the Contracts SdlValidationDiagnostic uses 0-based LSP line/character.
	SdlPositionMap performs that translation.
	-->

	<PropertyGroup>
		<RootNamespace>EllipticBit.SDLang.VisualStudio.LanguageServer</RootNamespace>
		<AssemblyName>EllipticBit.SDLang.VisualStudio.LanguageServer</AssemblyName>

		<!-- Deployed inside the VSIX, not shipped to NuGet; documentation is generated by the public Contracts assembly. -->
		<IsPackable>false</IsPackable>
		<GenerateDocumentationFile>false</GenerateDocumentationFile>
	</PropertyGroup>

	<ItemGroup>
		<!-- MEF v1 (ImportMany of ISdlSemanticValidator + metadata view) ships in the .NET Framework. -->
		<Reference Include="System.ComponentModel.Composition" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\EllipticBit.SDLang.Analysis\EllipticBit.SDLang.Analysis.csproj" />
		<ProjectReference Include="..\EllipticBit.SDLang.VisualStudio.Contracts\EllipticBit.SDLang.VisualStudio.Contracts.csproj" />
	</ItemGroup>

</Project>
