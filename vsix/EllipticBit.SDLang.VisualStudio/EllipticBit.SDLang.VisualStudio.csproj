<Project Sdk="Microsoft.NET.Sdk">

	<!--
	EllipticBit.SDLang.VisualStudio is the user-facing VSIX. It is a classic in-proc extension (net472, inherited
	from vsix/Directory.Build.props) so a single binary loads in both Visual Studio 2022 (17.x) and 2026 (18.x).

	Responsibilities:
	  - Ship the TextMate grammar (source.sdl) and language configuration (Grammars/*) for syntax highlighting,
		bracket/quote auto-close, comments, and indentation.
	  - Define the "sdlang" content type and map the .sdl/.sdlang extensions to it (SdlContentTypeDefinitions).
	  - Surface live diagnostics (squiggles + Error List) by driving the validated SdlLanguageEngine
		(SdlErrorTaggerProvider).
	  - Proffer the brokered ISdlLanguageService so out-of-MEF consumers (e.g. Visual D's dub.sdl) can reuse the
		same engine (SdlLanguagePackage).

	NOTE: Producing the final .vsix requires the VSSDK packaging targets, which are most reliable when built from
	within Visual Studio. The MEF/editor C# in this project compiles with a normal build; the .vsix container is
	generated by the VSSDK targets (CreateVsixContainer).
	-->

	<PropertyGroup>
		<RootNamespace>EllipticBit.SDLang.VisualStudio</RootNamespace>
		<AssemblyName>EllipticBit.SDLang.VisualStudio</AssemblyName>

		<!-- Classic in-proc VSIX packaging via VSSDK.BuildTools on an SDK-style project. -->
		<!--
		REQUIRED for SDK-style projects: Microsoft.VSSDK.BuildTools defaults VSSDKBuildToolsAutoSetup to false and
		only imports its packaging engine (Microsoft.VSSDK.targets: GeneratePkgDef, CreateVsixContainer,
		DeployVsixExtensionFiles, chained via PrepareForRunDependsOn) when this flag is true. The classic .csproj
		template imports those targets directly; an SDK-style project must opt in explicitly. Without this, the
		project compiles as a plain net472 class library and emits only a .dll (no .pkgdef, no .vsix).
		-->
		<VSSDKBuildToolsAutoSetup>true</VSSDKBuildToolsAutoSetup>
		<GeneratePkgDefFile>true</GeneratePkgDefFile>
		<IncludeAssemblyInVSIXContainer>true</IncludeAssemblyInVSIXContainer>
		<IncludeDebugSymbolsInVSIXContainer>false</IncludeDebugSymbolsInVSIXContainer>
		<IncludeDebugSymbolsInLocalVSIXDeployment>false</IncludeDebugSymbolsInLocalVSIXDeployment>
		<CopyBuildOutputToOutputDirectory>true</CopyBuildOutputToOutputDirectory>
		<CopyOutputSymbolsToOutputDirectory>false</CopyOutputSymbolsToOutputDirectory>

		<!-- This is a VSIX, never a NuGet package. -->
		<IsPackable>false</IsPackable>
		<GenerateDocumentationFile>false</GenerateDocumentationFile>
		<UseCodebase>true</UseCodebase>

		<!-- MEF components are deployed inside the VSIX; the VS host resolves the SDK assemblies at runtime. -->
		<DeployExtension Condition="'$(Configuration)' == 'Debug'">true</DeployExtension>
		<StartAction Condition="'$(Configuration)' == 'Debug'">Program</StartAction>
	</PropertyGroup>

	<ItemGroup>
		<!--
		The VS SDK reference assemblies. ExcludeAssets=runtime keeps the (very large) VS assembly closure OUT of
		the VSIX: the Visual Studio process supplies those assemblies at run time.
		-->
		<PackageReference Include="Microsoft.VisualStudio.SDK" Version="17.14.40265" ExcludeAssets="runtime" />

		<!-- Build-only: generates the .pkgdef and .vsix container. Not a runtime dependency. -->
		<PackageReference Include="Microsoft.VSSDK.BuildTools" Version="18.5.40034" PrivateAssets="all" />
	</ItemGroup>

	<ItemGroup>
		<!--
		The engine and contracts ARE shipped inside the VSIX (they are not provided by VS), so they flow into the
		container as MEF assemblies. Their transitive net472 dependencies are handled by the engine project.
		-->
		<ProjectReference Include="..\EllipticBit.SDLang.VisualStudio.LanguageServer\EllipticBit.SDLang.VisualStudio.LanguageServer.csproj" />
		<ProjectReference Include="..\EllipticBit.SDLang.VisualStudio.Contracts\EllipticBit.SDLang.VisualStudio.Contracts.csproj" />
		<ProjectReference Include="..\EllipticBit.SDLang.Analysis\EllipticBit.SDLang.Analysis.csproj" />
	</ItemGroup>

	<ItemGroup>
		<!-- The VSIX manifest. -->
		<None Include="source.extension.vsixmanifest">
			<SubType>Designer</SubType>
		</None>
	</ItemGroup>

	<ItemGroup>
		<!--
		The extension icon shown in the Extensions manager. The VSSDK does NOT package a file just because <Icon>
		references it, so it is included as VSIX content here and <Link> lands it at the VSIX root; the manifest's
		<Icon> then references that packaged name.
		-->
		<Content Include="..\..\sdl-icon.png">
			<Link>sdl-icon.png</Link>
			<IncludeInVSIX>true</IncludeInVSIX>
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</Content>
	</ItemGroup>

	<ItemGroup>
		<!--
		TextMate grammar + language configuration. They must be COPIED INTO the VSIX (IncludeInVSIX=true) under the
		Grammars\ folder so the editor's TextMate engine can load source.sdl for the sdlang content type.
		-->
		<Content Include="Grammars\sdlang.tmLanguage.json">
			<IncludeInVSIX>true</IncludeInVSIX>
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
			<VSIXSubPath>Grammars</VSIXSubPath>
		</Content>
		<Content Include="Grammars\sdlang.language-configuration.json">
			<IncludeInVSIX>true</IncludeInVSIX>
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
			<VSIXSubPath>Grammars</VSIXSubPath>
		</Content>
		<Content Include="Grammars\package.json">
			<IncludeInVSIX>true</IncludeInVSIX>
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
			<VSIXSubPath>Grammars</VSIXSubPath>
		</Content>
	</ItemGroup>

</Project>
